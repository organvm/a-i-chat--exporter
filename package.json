{
  "name": "@pionxzh/chatgpt-exporter",
  "type": "module",
  "version": "2.29.1",
  "private": true,
  "packageManager": "pnpm@8.14.1",
  "title": "ChatGPT Exporter",
  "title:zh-CN": "ChatGPT Exporter",
  "title:zh-TW": "ChatGPT Exporter",
  "description": "Easily export the whole ChatGPT conversation history for further analysis or sharing.",
  "description:zh-CN": "轻松导出 ChatGPT 聊天记录，以便进一步分析或分享。",
  "description:zh-TW": "輕鬆匯出 ChatGPT 聊天紀錄，以便進一步分析或分享。",
  "author": "pionxzh",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "site:build": "node scripts/build-site.mjs --build",
    "preview:site": "node scripts/build-site.mjs && npx --yes serve dist-site -l 8080",
    "deploy": "docker compose up -d --build",
    "deploy:docker": "docker compose up -d --build",
    "deploy:vercel": "npx --yes vercel deploy --prod",
    "deploy:cloudflare": "pnpm run site:build && npx --yes wrangler pages deploy dist-site --project-name chatgpt-exporter"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-hover-card": "^1.1.17",
    "hast-util-to-html": "^9.0.5",
    "html2canvas": "^1.4.1",
    "i18next": "^26.3.1",
    "jszip": "3.10.1",
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-hast": "^13.2.1",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-extension-gfm": "^3.0.0",
    "mitt": "^3.0.1",
    "preact": "^10.29.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "sanitize-filename": "^1.6.4",
    "sentinel-js": "^0.0.7",
    "urlcat": "^3.1.0",
    "vite-plugin-monkey": "^8.0.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@pionxzh/eslint-config": "^2.0.2",
    "@preact/preset-vite": "^2.10.5",
    "@types/katex": "^0.16.8",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.0.0",
    "@types/unist": "^3.0.3",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "katex": "^0.17.0",
    "lint-staged": "^17.0.7",
    "react": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "pnpm exec eslint"
  }
}
